{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "lib": ["ES2017"],
    "jsx": "react-native",
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
