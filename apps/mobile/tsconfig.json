{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "lib": ["ES2017"],
        "jsx": "react-native",
        "strict": true,
        "paths": {
            "@/*": ["./src/*"],
            "@/assets/*": ["./assets/*"],
            "@altarium/packages/*": ["../../packages/*"]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".expo/types/**/*.ts",
        "expo-env.d.ts",
        "nativewind-env.d.ts",
        "../../packages/core/utils/liturgical-items-mock.ts"
    ],
    "exclude": ["node_modules"]
}
