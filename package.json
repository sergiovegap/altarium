{
  "name": "altarium",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo dev --filter=@altarium/web",
    "dev:mobile": "turbo dev --filter=@altarium/mobile",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase db push",
    "db:studio": "supabase studio",
    "build": "turbo run build",
    "build:web": "turbo build --filter=@altarium/web",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.0",
    "typescript": "5.9.2",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/**/*"
  ],
  "dependencies": {
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "axios": "^1.14.0"
  }
}
